# Streamlit secrets — copy to .streamlit/secrets.toml and fill in.
# DO NOT commit the real secrets.toml (it is in .gitignore).

# ── Verifika QA API ────────────────────────────────────────────────────
# Two credential modes — pick one. If both are set, api_token wins.

# Mode 1: Long-lived Bearer token (preferred for headless use)
verifika_api_token = ""

# Mode 2: Username + password (login flow, token refreshed automatically)
verifika_username = ""
verifika_password = ""

# Optional: override the default API base URL
# verifika_base_url = "https://beta.e-verifika.com"
